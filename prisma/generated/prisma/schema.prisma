// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model tbUser {
  id              String          @id @default(uuid())
  idUser          String?         @unique
  nomeUser        String?
  emailUser       String?         @unique
  emailVerified   DateTime?
  senhaUser       String?
  avatarUser      String?
  authTypeUser    String?
  formulariosUser Json?
  centrosUser     Json?
  statusUser      String          @default("ATIVO")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tbFuncioanrio   tbFuncionario[]
}

model tbFuncionario {
  idF                     String                    @id @default(uuid())
  idMatFun                String                    @unique
  nomeFun                 String
  cpfFun                  String?
  dataAdmFun              DateTime?
  dataDesFun              DateTime?
  avatarFun               String?
  idFuncaoFun             String?
  idUserFun               String?
  idStatusFun             String?
  idCustoFun              String?
  tbStatusFun             tbStatusFun?              @relation(fields: [idStatusFun], references: [idStatusFun])
  tbUser                  tbUser?                   @relation(fields: [idUserFun], references: [id])
  tbFuncao                tbFuncao?                 @relation(fields: [idFuncaoFun], references: [idFuncao])
  tbCCusto                tbCCusto?                 @relation(fields: [idCustoFun], references: [idCCusto])
  tbCadastro              tbCadastro[]
  tbHasLicencaFuncionario tbHasLicencaFuncionario[]
}

model tbLicenca {
  idLic                   String                    @id @default(uuid())
  descricaoLic            String
  tbHasLicencaFuncionario tbHasLicencaFuncionario[]
}

model tbHasLicencaFuncionario {
  idHas          String        @id @default(uuid()) @map("id_has")
  idFunc         String        @map("idfunc")
  idLinc         String        @map("idLinc")
  dataInicio     DateTime      @map("datainicio")
  dataVencimetno DateTime      @map("datavencimetno")
  tbFuncionario  tbFuncionario @relation(fields: [idFunc], references: [idF], onDelete: Cascade)
  tbLicenca      tbLicenca     @relation(fields: [idLinc], references: [idLic], onDelete: Cascade)

  @@unique([idFunc, idLinc])
  @@index([idFunc])
  @@index([idLinc])
  @@map("has_")
}

model tbStatusFun {
  idStatusFun        String          @id @default(uuid())
  descricaoStatusFun String
  tbFuncionario      tbFuncionario[]
}

model tbFuncao {
  idFuncao      String          @id @default(uuid())
  codigoFuncao  Int             @unique @default(autoincrement())
  nomeFuncao    String
  tbFuncionario tbFuncionario[]
}

model tbPatrimonio {
  idP                   String       @id @default(uuid())
  idPat                 String       @unique
  descricaoPat          String
  descricaoDetalhadaPat String?
  licencaPat            String?
  dataEntPat            DateTime
  dataSaiPat            DateTime?
  notaFiscalPat         String?
  valorPat              Float
  createdAt             DateTime?    @default(now())
  updatedAt             DateTime?    @updatedAt
  idPat_TipoPat         String?
  tbTipoPat             tbTipoPat?   @relation(fields: [idPat_TipoPat], references: [idTipPat])
  idPat_StatusPat       String?
  tbStatusPat           tbStatusPat? @relation(fields: [idPat_StatusPat], references: [idStatusPat])
  idPat_CustoPat        String?
  tbCCusto              tbCCusto?    @relation(fields: [idPat_CustoPat], references: [idCCusto])
  tbCadastro            tbCadastro[]
}

model tbTipoPat {
  idTipPat        String         @id @default(uuid())
  descricaoTipPat String?
  tbPatrimonio    tbPatrimonio[]
}

model tbStatusPat {
  idStatusPat      String         @id @default(uuid())
  descricaoStatPat String
  tbPatrimonio     tbPatrimonio[]
  tbCadastro       tbCadastro[]
}

model tbEmpresa {
  idEmp           String     @id @default(uuid())
  razaoEmpresa    String?
  fantasiaEmpresa String?
  cnpjEmpresa     String?
  idCustEmp       String?
  tbCCusto        tbCCusto[]
}

model tbCCusto {
  idCCusto        String          @id @default(uuid())
  codigoCCusto    String?
  descricaoCCusto String?
  idEmp_Custo     String?
  tbEmpresa       tbEmpresa?      @relation(fields: [idEmp_Custo], references: [idEmp])
  tbPatrimonio    tbPatrimonio[]
  tbFuncionario   tbFuncionario[]
}

model tbCadastro {
  idCad          String         @id @default(uuid())
  dataCadPat     DateTime?
  dataDevPat     DateTime?
  createdAt      DateTime?      @default(now())
  updatedAt      DateTime?      @updatedAt
  idPatCad       String?
  tbPatrimonio   tbPatrimonio?  @relation(fields: [idPatCad], references: [idPat])
  idMatFunCad    String?
  tbFuncionario  tbFuncionario? @relation(fields: [idMatFunCad], references: [idMatFun])
  idStatusPatCad String
  tbStatusPat    tbStatusPat?   @relation(fields: [idStatusPatCad], references: [idStatusPat])
}

model Account {
  idAccont          String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  sesseion_state    String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String    @unique
  expires    DateTime?

  @@unique([identifier, token])
  @@map("VerificationTokens")
}
