# Banco de dados (Prisma)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DB_NAME"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-a-long-random-secret"

# Login admin local
ADMIN_EMAIL="admin@empresa.com"
ADMIN_PASSWORD="change-me"

# OAuth Google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Next.js dev origins (opcional, separado por virgula)
DEV_ALLOWED_ORIGINS="localhost:3000,127.0.0.1:3000"

# Dashboard auto-refresh (ms)
# 30000 = 30s (padrao)
# 0 = desabilita auto-refresh
NEXT_PUBLIC_DASHBOARD_REFRESH_MS=30000
