{
    "DockerRun.DisableDockerrc": true,
    "DockerRun.DisableAutoGenerateConfig": true,
    "chat.editRequests": "none",
    "chatgpt.runCodexInWindowsSubsystemForLinux": true,
    "prisma.schemaPath": "prisma/schema.prisma",
    "files.watcherExclude": {
        "**/prisma/generated/**": true
    },
    "search.exclude": {
        "**/prisma/generated/**": true
    },
    "sqltools.connections": [
        {
            "mysqlOptions": {
                "authProtocol": "default",
                "enableSsl": "Disabled"
            },
            "ssh": "Disabled",
            "previewLimit": 50,
            "server": "localhost",
            "port": 3306,
            "driver": "MySQL",
            "name": "Banco APPGPP",
            "database": "dbapp",
            "username": "root"
        }
    ]
}
